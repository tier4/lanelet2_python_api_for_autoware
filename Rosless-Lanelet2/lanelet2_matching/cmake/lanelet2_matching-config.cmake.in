@PACKAGE_INIT@

include(CMakeFindDependencyMacro)

# List all dependencies that need to be found
find_dependency(Eigen3)
find_dependency(Boost COMPONENTS system filesystem program_options)
find_dependency(lanelet2_core)
find_dependency(lanelet2_traffic_rules)

# Include targets file
include("${CMAKE_CURRENT_LIST_DIR}/@PROJECT_NAME@-targets.cmake")

# Set any additional variables, if needed
set(lanelet2_matching_FOUND TRUE)
