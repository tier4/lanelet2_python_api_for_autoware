+// Helper functions to convert byte arrays to Eigen vectors
+Eigen::Vector3d bytesToVector3d(const std::string & bytes)
+{
+  if (bytes.size() != sizeof(double) * 3) {
+    throw std::runtime_error("Invalid byte array size for Vector3d");
+  }
+  const double * data = reinterpret_cast<const double *>(bytes.data());
+  return Eigen::Vector3d(data[0], data[1], data[2]);
+}
+
+Eigen::Vector4d bytesToVector4d(const std::string & bytes)
+{
+  if (bytes.size() != sizeof(double) * 4) {
+    throw std::runtime_error("Invalid byte array size for Vector4d");
+  }
+  const double * data = reinterpret_cast<const double *>(bytes.data());
+  return Eigen::Vector4d(data[0], data[1], data[2], data[3]);
+}
